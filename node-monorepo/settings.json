{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run dev:server)",
      "Bash(npm run dev:web)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm install)",
      "Bash(npm -w packages/server run build)",
      "Bash(npm -w packages/server run dev)",
      "Bash(npm -w packages/web run build)",
      "Bash(npm -w packages/web run dev)",
      "Bash(npx tsc --noEmit*)"
    ],
    "deny": [
      "Bash(npm publish)",
      "Bash(rm -rf*)",
      "Bash(git push --force*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-secrets.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-bash.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-typecheck.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v notify-send >/dev/null 2>&1 && notify-send -i dialog-information 'Claude Code' 'Czeka na Twoją odpowiedź'"
          }
        ]
      }
    ]
  }
}
